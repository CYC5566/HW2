@model USUN2.Common.Models.LoginInput
@{
    ViewData["Title"] = "登入";
    var returnUrl = ViewData["ReturnUrl"] as string;
}

<div class="row justify-content-center">
    <div class="col-md-6 col-lg-5">
        <h1 class="h3 mb-3">登入</h1>
        <p class="text-muted small">請輸入身分證字號(10 碼)。無需密碼。</p>
        <div class="card shadow-sm">
            <div class="card-body">
                <form asp-action="Login" method="post" asp-route-returnUrl="@returnUrl">
                    @Html.AntiForgeryToken()
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
                    <div class="mb-3">
                        <label asp-for="UserId" class="form-label"></label>
                        <input asp-for="UserId" class="form-control" autocomplete="username" maxlength="10" />
                        <span asp-validation-for="UserId" class="text-danger"></span>
                    </div>
                    <button type="submit" class="btn btn-primary w-100">登入</button>
                </form>
                <p class="mt-3 mb-0 text-center small">
                    還沒有帳號?<a asp-action="Register">立即註冊</a>
                </p>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
