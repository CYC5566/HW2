@model USUN2.Common.Models.UserCreateInput
@{
    ViewData["Title"] = "註冊";
}

<h1 class="h3 mb-3">註冊帳號</h1>
<p class="text-muted">使用身分證字號作為帳號，無需密碼。註冊成功後將自動登入。</p>

<div class="row justify-content-center">
    <div class="col-lg-8">
        <div class="card shadow-sm">
            <div class="card-body">
                <form asp-action="Register" method="post" novalidate>
                    @Html.AntiForgeryToken()
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                    <div class="mb-3">
                        <label asp-for="UserId" class="form-label"></label>
                        <input asp-for="UserId" class="form-control" maxlength="10" autocomplete="off" />
                        <span asp-validation-for="UserId" class="text-danger"></span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="UserName" class="form-label"></label>
                        <input asp-for="UserName" class="form-control" autocomplete="name" />
                        <span asp-validation-for="UserName" class="text-danger"></span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="Email" class="form-label"></label>
                        <input asp-for="Email" class="form-control" autocomplete="email" />
                        <span asp-validation-for="Email" class="text-danger"></span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="Account" class="form-label"></label>
                        <input asp-for="Account" class="form-control" maxlength="50" autocomplete="off" />
                        <span asp-validation-for="Account" class="text-danger"></span>
                    </div>

                    <div class="d-flex flex-wrap gap-2">
                        <button type="submit" class="btn btn-primary">註冊</button>
                        <a class="btn btn-outline-secondary" asp-action="Login">已有帳號?登入</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
